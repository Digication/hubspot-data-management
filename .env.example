# HubSpot API credentials for Phase 2 scripts.
#
# HOW TO GET THIS TOKEN:
#   1. In HubSpot, go to: Settings → Integrations → Private Apps
#   2. Click "Create a private app"
#   3. Name it: "CRM Cleanup Phase 2 (read-only)"
#   4. On the "Scopes" tab, enable ONLY these read scopes:
#        - crm.objects.contacts.read
#        - crm.objects.companies.read
#        - crm.objects.deals.read
#        - crm.schemas.contacts.read
#        - crm.schemas.companies.read
#        - crm.schemas.deals.read
#        - crm.pipelines.deals.read
#   5. Click "Create app", confirm, and copy the access token
#   6. Paste the token as the value below
#
# DO NOT COMMIT .env TO GIT. The .env file is gitignored.
# Rotate/delete this token after Phase 2 execution completes.

HUBSPOT_ACCESS_TOKEN=paste-your-token-here
